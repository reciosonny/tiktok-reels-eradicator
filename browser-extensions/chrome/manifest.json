{
    "name": "Feed breaker",
    "description": "Feed breaker helps you take back control of your time by removing social media's addictive feed and short-form contents.",
    "version": "1.0.5",
    "manifest_version": 3,
    "icons": {
        "128": "images/default.png",
        "19": "images/default.png"
    },
    "background": {
        "service_worker": "./background.js"
    },
    "content_scripts": [
        {
            "matches": ["*://www.tiktok.com/*", "*://tiktok.com/*"],
            "js": ["./dist/index.js"],
            "run_at": "document_idle"
        }
    ],
    "action": {
        "default_icons": {
            "128": "images/default.png"
        }
    },
    "options_page": "options.html",
    "permissions": ["storage"],
    "host_permissions": ["*://www.tiktok.com/*", "*://tiktok.com/*"],
    "web_accessible_resources": [
        {
            "resources": ["fonts/*"],
            "matches": ["*://www.tiktok.com/*", "*://tiktok.com/*"]
        }
    ]
}
